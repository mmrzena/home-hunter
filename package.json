{
  "name": "home-hunter",
  "version": "0.1.0",
  "description": "Personal house-hunting tool — dedupes Czech property listings and scores them on price percentile, commute distance, and trust.",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "ui:add": "shadcn add",
    "db:up": "docker compose up -d postgis",
    "db:migrate": "tsx worker/db/migrate.ts",
    "db:seed": "tsx worker/seed/areas.ts",
    "worker": "tsx worker/index.ts",
    "pipeline": "tsx worker/cli.ts pipeline",
    "ingest": "tsx worker/cli.ts ingest",
    "hash": "tsx worker/cli.ts hash",
    "bucket": "tsx worker/cli.ts bucket",
    "dedupe": "tsx worker/cli.ts dedupe",
    "score": "tsx worker/cli.ts score"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@remixicon/react": "^4.9.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "drizzle-orm": "^0.36.4",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "maplibre-gl": "^4.7.1",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "node-cron": "^3.0.3",
    "p-limit": "^6.1.0",
    "postgres": "^3.4.5",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.0",
    "sharp": "^0.33.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.28.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  }
}
