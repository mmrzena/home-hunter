# Postgres + PostGIS. The docker-compose default — override for Neon/Vercel Postgres.
DATABASE_URL=postgres://hunter:hunter@localhost:5432/hunter

# Optional anchor point (e.g. your workplace) for commute distance + bearing on cards.
# ANCHOR_LAT=50.0875
# ANCHOR_LNG=14.4213
# ANCHOR_LABEL=Work

# Ingest tuning
ENABLE_BEZREALITKY=false
INGEST_MAX_PAGES=40
REQUEST_DELAY_MS=1200
IMAGE_CONCURRENCY=3
MAX_IMAGES_PER_LISTING=8

# Feed window for "new / price-changed" listings (hours)
FEED_WINDOW_HOURS=48
